# Plantilla de variables de entorno
# COPIAR a .env.local y completar con tus valores
# NO comitear este archivo si contiene datos sensibles

# AWS Configuration
AWS_REGION=us-east-2
AWS_PROFILE=default

# Database
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_NAME=cooking_eggs_db
DB_USER=admin
# DB_PASSWORD se obtiene desde SSM en Lambda

# Cognito
COGNITO_REGION=us-east-2
COGNITO_USER_POOL_ID=us-east-2_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxx
# COGNITO_CLIENT_SECRET se obtiene desde SSM en Lambda

# Bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# Frontend
REACT_APP_API_URL=https://your-api-gateway-url.execute-api.us-east-2.amazonaws.com
